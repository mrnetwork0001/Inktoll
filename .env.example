# Circle API Credentials
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/nanopayments
CIRCLE_WALLET_SET_ID=your_circle_wallet_set_id_here

# Arc Testnet Settings
