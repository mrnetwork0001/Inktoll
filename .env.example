# Circle API Credentials
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_GATEWAY_URL=https://gateway-api-testnet.circle.com
CIRCLE_WALLET_SET_ID=your_circle_wallet_set_id_here
CIRCLE_ENTITY_SECRET=your_circle_entity_secret_hex_here

# Arc Network Settings
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_VERIFYING_CONTRACT=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
ARC_BLOCKCHAIN_NAME=ARC-TESTNET
ARC_CHAIN_NAME=arcTestnet

# AI Agent Wallet Configurations
# Optional: Set this to force the AI Agent to use a specific secure private key instead of generating one local JSON file
AGENT_PRIVATE_KEY=

# OpenAI Configurations
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Real Ghost Blog Details (Leave empty to use automatic mock mode)
GHOST_BLOG_URL=
GHOST_CONTENT_API_KEY=

# Server Configuration
PORT=3001
DATABASE_PATH=./data/inktoll.db

# Frontend Configurations
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ARC_MAINNET=false
